# Core feeds + globe run KEYLESS out of the box. These are optional upgrades.
# Copy this file to `.env` and fill in what you have, then restart `npm run dev`.

# ── AI DAILY BRIEF ──────────────────────────────────────────────────────────
# Powers the AI-synthesized Daily Brief (executive summary, market analysis,
# business signals, opportunities, predictions). Generated once per day and
# cached, so cost is ~cents/day. Without a key the brief falls back to the
# live-derived (non-AI) analysis.
# Get a key: https://console.anthropic.com  →  API Keys
ANTHROPIC_API_KEY=
# Optional model override (defaults to claude-opus-4-8; use claude-haiku-4-5 to cut cost).
ANTHROPIC_MODEL=

# Persistent daily cache (recommended for Vercel — guarantees ONE generation/day).
# Add the "Upstash for Redis" / KV integration in Vercel and it auto-injects these.
# Without them, the brief caches to a temp file (works, but may regenerate on cold starts).
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Production credit-guard: set this to any long random string in Vercel.
# Vercel Cron sends it as `Authorization: Bearer <CRON_SECRET>`, so ONLY the daily
# cron can trigger a (paid) brief generation — visitors only ever read the cache.
# Leave empty in local dev to allow on-demand generation while building.
CRON_SECRET=

# ── GLOBE ───────────────────────────────────────────────────────────────────
# Google Photorealistic 3D Tiles — real 3D buildings/terrain (the spy-movie look).
# Enable "Map Tiles API" in Google Cloud, create an API key (browser key).
# https://developers.google.com/maps/documentation/tile/3d-tiles-overview
# Without this, the globe uses keyless Esri World Imagery (still detailed + zoomable).
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Optional: your own free Cesium Ion token (only if you switch back to Ion imagery).
# https://ion.cesium.com
NEXT_PUBLIC_CESIUM_ION_TOKEN=

# ── FLIGHTS ─────────────────────────────────────────────────────────────────
# OpenSky Network — anonymous works but is heavily quota-limited.
# For production/live use, create an API client on your OpenSky account page:
# https://opensky-network.org
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Optional: use an already-minted Bearer token instead of client credentials.
OPENSKY_ACCESS_TOKEN=

# Quota controls. Global /states/all costs credits, so keep this conservative.
# Authenticated default is 90000 ms; anonymous default is 900000 ms.
OPENSKY_REFRESH_MS=
OPENSKY_MAX_FLIGHTS=2500

# Optional bounding box to reduce OpenSky credit cost:
# lamin,lomin,lamax,lomax (example below covers Malaysia/Singapore airspace)
# OPENSKY_BOUNDS=0.7,99.0,7.5,105.5

# ADS-B Exchange (military / unfiltered flights) via RapidAPI — paid.
# https://adsbexchange.com  /  https://rapidapi.com/adsbx/api/adsbexchange-com1
ADSBX_RAPIDAPI_KEY=
